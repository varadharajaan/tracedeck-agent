{
  "info": {
    "name": "TraceDeck Backend Phase 100",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health No Store Header",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('health is ok and not cached', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "  pm.expect(pm.response.headers.get('Cache-Control')).to.eql('no-store, no-cache, must-revalidate, max-age=0');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Dashboard Has Operator Assurance Center",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('dashboard contains operator assurance center markers', function () {",
              "  pm.response.to.have.status(200);",
              "  const html = pm.response.text();",
              "  pm.expect(html).to.include('Operator Assurance Center');",
              "  pm.expect(html).to.include('Assurance Cards');",
              "  pm.expect(html).to.include('Assurance Actions');",
              "  pm.expect(html).to.include('operator-assurance-status');",
              "  pm.expect(html).to.include('assurance-card-list');",
              "  pm.expect(html).to.include('assurance-action-list');",
              "  pm.expect(html).to.include('Operator Assurance');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Operator Assurance Center API",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/operator-assurance-center"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('operator assurance center is typed and metadata-only', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.source).to.eql('phase100_operator_assurance');",
              "  pm.expect(body.summary.status).to.be.a('string').and.not.empty;",
              "  pm.expect(body.summary.scheduler_explanation).to.be.a('string').and.not.empty;",
              "  pm.expect(body.summary.frontend_cache_status).to.be.a('string').and.not.empty;",
              "  pm.expect(body.summary.frontend_cache_hit_pct).to.be.a('number');",
              "  pm.expect(body.cards.length).to.be.at.least(6);",
              "  pm.expect(body.actions.length).to.be.above(0);",
              "  body.cards.forEach((item) => {",
              "    pm.expect(item.id).to.be.a('string').and.not.empty;",
              "    pm.expect(item.label).to.be.a('string').and.not.empty;",
              "    pm.expect(item.status).to.be.a('string').and.not.empty;",
              "    pm.expect(item.evidence_scope).to.eql('metadata_only');",
              "  });",
              "  pm.expect(body.privacy_boundary).to.include('metadata-only');",
              "  const serialized = JSON.stringify(body).toLowerCase();",
              "  ['smtp_password', 'provider_secret', 'push_endpoint', 'screenshot_bytes', 'raw_url', 'page_title', 'alert_body', 'card_number', 'cvv', 'payment_token', 'keylogger'].forEach((marker) => {",
              "    pm.expect(serialized).to.not.include(marker);",
              "  });",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:18080" }
  ]
}
