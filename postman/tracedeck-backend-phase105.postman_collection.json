{
  "info": {
    "name": "TraceDeck Backend Phase 105",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health No Store Header",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('health is ok and not cached', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "  pm.expect(pm.response.headers.get('Cache-Control')).to.eql('no-store, no-cache, must-revalidate, max-age=0');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Dashboard Has Promotion Readiness Center",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('dashboard contains promotion readiness markers', function () {",
              "  pm.response.to.have.status(200);",
              "  const html = pm.response.text();",
              "  pm.expect(html).to.include('Promotion Readiness Center');",
              "  pm.expect(html).to.include('Promotion Proof');",
              "  pm.expect(html).to.include('Promotion Actions');",
              "  pm.expect(html).to.include('promotion-readiness-status');",
              "  pm.expect(html).to.include('promotion-proof-list');",
              "  pm.expect(html).to.include('promotion-action-list');",
              "  pm.expect(html).to.include('Promotion Readiness');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Promotion Readiness Center API",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/promotion-readiness-center"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('promotion readiness center is typed and metadata-only', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.headers.get('Cache-Control')).to.eql('no-store, no-cache, must-revalidate, max-age=0');",
              "  const body = pm.response.json();",
              "  pm.expect(body.source).to.eql('phase105_promotion_readiness');",
              "  pm.expect(body.summary.status).to.be.a('string').and.not.empty;",
              "  pm.expect(body.summary.can_promote).to.be.a('boolean');",
              "  pm.expect(body.summary.runtime_ready).to.be.a('boolean');",
              "  pm.expect(body.summary.verification_ready).to.be.a('boolean');",
              "  pm.expect(body.summary.assurance_ready).to.be.a('boolean');",
              "  pm.expect(body.summary.git_clean).to.be.a('boolean');",
              "  pm.expect(body.summary.ready_pid_status).to.be.a('string').and.not.empty;",
              "  pm.expect(body.summary.scheduler_readback).to.be.a('string').and.not.empty;",
              "  pm.expect(body.summary.gates_ok).to.be.a('number');",
              "  pm.expect(body.summary.gates_total).to.be.a('number');",
              "  pm.expect(body.proof.length).to.be.at.least(6);",
              "  pm.expect(body.actions.length).to.be.above(0);",
              "  body.proof.forEach((item) => {",
              "    pm.expect(item.id).to.be.a('string').and.not.empty;",
              "    pm.expect(item.label).to.be.a('string').and.not.empty;",
              "    pm.expect(item.status).to.be.a('string').and.not.empty;",
              "    pm.expect(item.evidence_scope).to.eql('metadata_only');",
              "  });",
              "  body.actions.forEach((item) => {",
              "    pm.expect(item.id).to.be.a('string').and.not.empty;",
              "    pm.expect(item.command).to.be.a('string').and.not.empty;",
              "    pm.expect(item.evidence_scope).to.eql('metadata_only');",
              "  });",
              "  pm.expect(body.privacy_boundary).to.include('metadata-only');",
              "  const serialized = JSON.stringify(body).toLowerCase();",
              "  ['smtp_password', 'provider_secret', 'push_endpoint', 'screenshot_bytes', 'raw_url', 'page_title', 'alert_body', 'card_number', 'cvv', 'payment_token', 'keylogger'].forEach((marker) => {",
              "    pm.expect(serialized).to.not.include(marker);",
              "  });",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:18080" }
  ]
}
