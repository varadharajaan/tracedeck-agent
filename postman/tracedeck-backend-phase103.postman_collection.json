{
  "info": {
    "name": "TraceDeck Backend Phase 103",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health No Store Header",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('health is ok and not cached', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "  pm.expect(pm.response.headers.get('Cache-Control')).to.eql('no-store, no-cache, must-revalidate, max-age=0');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Runtime Status Ready Refresh Command",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/runtime-status-center"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('runtime status exposes runnable ready PID refresh command', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.summary.runtime_ok).to.eql(true);",
              "  pm.expect(body.summary.health_ok).to.eql(true);",
              "  pm.expect(body.summary.ready_pid_status).to.eql('stale');",
              "  const refreshAction = body.actions.find((item) => item.id === 'refresh-ready-pid-proof');",
              "  pm.expect(refreshAction).to.be.an('object');",
              "  pm.expect(refreshAction.command).to.eql('python ./devctl.py server task-refresh-ready');",
              "  pm.expect(refreshAction.evidence_scope).to.eql('metadata_only');",
              "  const serialized = JSON.stringify(body).toLowerCase();",
              "  ['smtp_password', 'provider_secret', 'push_endpoint', 'screenshot_bytes', 'raw_url', 'page_title', 'alert_body', 'card_number', 'cvv', 'payment_token', 'keylogger'].forEach((marker) => {",
              "    pm.expect(serialized).to.not.include(marker);",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Operator Assurance Ready Refresh Command",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/operator-assurance-center"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('operator assurance exposes runnable ready PID refresh command', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  const refreshAction = body.actions.find((item) => item.id === 'refresh-ready-pid-proof');",
              "  pm.expect(refreshAction).to.be.an('object');",
              "  pm.expect(refreshAction.command).to.eql('python ./devctl.py server task-refresh-ready');",
              "  pm.expect(body.privacy_boundary).to.include('metadata-only');",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:18080" }
  ]
}
