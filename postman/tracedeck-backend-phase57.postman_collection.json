{
  "info": {
    "name": "TraceDeck Backend Phase 57",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('health is ok', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Dashboard Has Customer Control Room",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('dashboard contains customer control markers', function () {",
              "  pm.response.to.have.status(200);",
              "  const html = pm.response.text();",
              "  pm.expect(html).to.include('Customer Control Room');",
              "  pm.expect(html).to.include('Customer Value Tiles');",
              "  pm.expect(html).to.include('Anomaly Command Wall');",
              "  pm.expect(html).to.include('Mail And Push Delivery');",
              "  pm.expect(html).to.include('Owner Monetisation Actions');",
              "  pm.expect(html).to.include('data-jump-target=\"customer-control-section\"');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Tenant Customer Control Room",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/tenants/family-varadha/customer-control-room"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('customer control room exposes monetisation proof', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.summary.product_score).to.be.above(0);",
              "  pm.expect(body.summary.notification_score).to.be.above(0);",
              "  pm.expect(body.summary.package_score).to.be.above(0);",
              "  pm.expect(body.summary.mail_delivered).to.be.above(0);",
              "  pm.expect(body.summary.dashboard_delivered).to.be.above(0);",
              "  pm.expect(body.summary.next_best_action).to.be.a('string').and.not.empty;",
              "  pm.expect(body.tiles.length).to.be.at.least(8);",
              "  pm.expect(body.alerts.length).to.be.at.least(1);",
              "  pm.expect(body.deliveries.length).to.be.at.least(3);",
              "  pm.expect(body.actions.length).to.be.at.least(1);",
              "  pm.expect(body.deliveries.some((item) => item.channel === 'push' && item.status)).to.eql(true);",
              "  pm.expect(body.privacy_boundary).to.include('metadata-only');",
              "  pm.expect(body.privacy_boundary).to.include('no passwords');",
              "  const serialized = JSON.stringify(body).toLowerCase();",
              "  ['smtp_password', 'provider_secret', 'screenshot_bytes', 'raw_url', 'page_title', 'alert_body', 'card_number', 'cvv', 'payment_token'].forEach(function (marker) {",
              "    pm.expect(serialized).to.not.include(marker);",
              "  });",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
