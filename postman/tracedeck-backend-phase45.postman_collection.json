{
  "info": {
    "name": "TraceDeck Backend Phase 45",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": { "method": "GET", "url": "{{baseUrl}}/health" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('health is ok', function () { pm.response.to.have.status(200); pm.expect(pm.response.json().status).to.eql('ok'); });"
      ] } }]
    },
    {
      "name": "Dashboard Has Monetisation Command Center",
      "request": { "method": "GET", "url": "{{baseUrl}}/" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('dashboard contains premium command center markers', function () {",
        "  pm.response.to.have.status(200);",
        "  const html = pm.response.text();",
        "  pm.expect(html).to.include('Monetisation Command Center');",
        "  pm.expect(html).to.include('Anomaly And Notification Inbox');",
        "  pm.expect(html).to.include('Delivery And Mail Proof');",
        "  pm.expect(html).to.include('Owner Action Queue');",
        "  pm.expect(html).to.include('command-center-delivery-list');",
        "});"
      ] } }]
    },
    {
      "name": "Tenant Operations Feed Command Center",
      "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/tenants/family-varadha/operations-summary" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('operations summary exposes fleet, anomaly, notification, and archive proof', function () {",
        "  pm.response.to.have.status(200);",
        "  const body = pm.response.json();",
        "  pm.expect(body.hosts_total).to.be.at.least(1);",
        "  pm.expect(body.open_anomalies).to.be.at.least(1);",
        "  pm.expect(body.notification_score).to.be.at.least(1);",
        "  pm.expect(body.delivery_total).to.be.at.least(3);",
        "});"
      ] } }]
    },
    {
      "name": "Tenant Monetization Feed Command Center",
      "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/tenants/family-varadha/monetization-summary" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('monetization summary exposes paid package readiness and routes', function () {",
        "  pm.response.to.have.status(200);",
        "  const body = pm.response.json();",
        "  pm.expect(body.readiness_score).to.be.at.least(1);",
        "  pm.expect(body.notification_routes.length).to.be.at.least(3);",
        "  pm.expect(body.paid_capabilities.length).to.be.at.least(3);",
        "});"
      ] } }]
    },
    {
      "name": "Tenant Alert Inbox Feeds Command Center",
      "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/tenants/family-varadha/alert-inbox" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('alert inbox exposes routed anomaly proof', function () {",
        "  pm.response.to.have.status(200);",
        "  const body = pm.response.json();",
        "  pm.expect(body.summary.open).to.be.at.least(1);",
        "  pm.expect(body.summary.notification_ready).to.be.at.least(1);",
        "  pm.expect(body.items.length).to.be.at.least(1);",
        "});"
      ] } }]
    },
    {
      "name": "Delivery Drilldown Remains Provider Safe",
      "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/tenants/family-varadha/delivery-drilldown" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('delivery drilldown feeds command center without secrets or content payloads', function () {",
        "  pm.response.to.have.status(200);",
        "  const body = pm.response.json();",
        "  pm.expect(body.privacy_boundary).to.include('no provider secrets');",
        "  pm.expect(body.summary.routes_total).to.be.at.least(3);",
        "  pm.expect(JSON.stringify(body).toLowerCase()).to.not.include('smtp_password');",
        "  pm.expect(JSON.stringify(body).toLowerCase()).to.not.include('provider_secret');",
        "  pm.expect(JSON.stringify(body).toLowerCase()).to.not.include('screenshot_bytes');",
        "});"
      ] } }]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:18080" }
  ]
}
