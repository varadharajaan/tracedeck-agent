{
  "info": {
    "name": "TraceDeck Backend Phase 89",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health No Store Header",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('health is ok and not cached', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "  pm.expect(pm.response.headers.get('Cache-Control')).to.eql('no-store, no-cache, must-revalidate, max-age=0');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Default Host Policy Evidence Is Live Only",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/devices/demo-study-laptop/policy-violations"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('default policy endpoint excludes seeded VLC evidence', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  const text = pm.response.text();",
              "  pm.expect(body.count).to.eql(0);",
              "  pm.expect(body.items).to.be.an('array').that.is.empty;",
              "  pm.expect(text).to.not.include('VLC media player');",
              "  pm.expect(text).to.not.include('demo_seed');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Default Tenant Activity Feed Evidence Is Live Only",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/tenants/family-varadha/activity-feed?device_id=demo-study-laptop&limit=10"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('default activity feed excludes seeded VLC evidence', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  const text = pm.response.text();",
              "  pm.expect(body.filters.include_demo).to.eql(false);",
              "  pm.expect(body.summary.risk_items).to.eql(0);",
              "  pm.expect(body.summary.delivery_items).to.eql(0);",
              "  pm.expect(text).to.not.include('VLC media player');",
              "  pm.expect(text).to.not.include('demo_seed');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Opt In Demo Activity Feed Evidence Is Labelled",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/tenants/family-varadha/activity-feed?device_id=demo-study-laptop&limit=10&include_demo=true"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('demo activity feed evidence remains explicit and labelled', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  const text = pm.response.text();",
              "  pm.expect(body.filters.include_demo).to.eql(true);",
              "  pm.expect(body.summary.risk_items).to.be.above(0);",
              "  pm.expect(text).to.include('VLC media player');",
              "  pm.expect(text).to.include('demo_seed');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Opt In Demo Policy Evidence Is Labelled",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/devices/demo-study-laptop/policy-violations?include_demo=true"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('demo policy evidence remains explicit and labelled', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.count).to.be.above(0);",
              "  pm.expect(body.items[0].source_kind).to.eql('demo_seed');",
              "  pm.expect(body.items[0].evidence_scope).to.eql('demo');",
              "  pm.expect(body.items[0].app_name).to.eql('VLC media player');",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:18080" }
  ]
}
