{
  "info": {
    "name": "TraceDeck Backend Phase 16",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Without API Key",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('health is public', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Tenant With API Key",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-TraceDeck-API-Key", "value": "{{apiKey}}" },
          { "key": "X-TraceDeck-Tenant-ID", "value": "family-varadha" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"tenant_id\":\"family-varadha\",\"name\":\"Family Varadha\",\"plan_id\":\"family_pro\",\"retention_tier_id\":\"family_cloud_90_365_archive\",\"primary_profile\":\"ai-btech-student\"}"
        },
        "url": "{{baseUrl}}/api/v1/tenants"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('tenant created with api key', function () {",
              "  pm.response.to.have.status(201);",
              "  pm.expect(pm.response.json().tenant_id).to.eql('family-varadha');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Enroll Device With API Key",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-TraceDeck-API-Key", "value": "{{apiKey}}" },
          { "key": "X-TraceDeck-Tenant-ID", "value": "family-varadha" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"tenant_id\":\"family-varadha\",\"device_id\":\"postman-phase16-device\",\"host_name\":\"postman-phase16-host\",\"profile\":\"ai-btech-student\",\"os_name\":\"windows\"}"
        },
        "url": "{{baseUrl}}/api/v1/devices/enroll"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('device enrolled with api key', function () {",
              "  pm.response.to.have.status(201);",
              "  pm.expect(pm.response.json().device_id).to.eql('postman-phase16-device');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Host Overview Has Product Signals",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-TraceDeck-API-Key", "value": "{{apiKey}}" },
          { "key": "X-TraceDeck-Tenant-ID", "value": "family-varadha" }
        ],
        "url": "{{baseUrl}}/api/v1/devices/postman-phase16-device/overview"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('overview includes risk, health, archive, and delivery state', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.policy_violations.length).to.be.above(0);",
              "  pm.expect(body.anomalies.length).to.be.above(0);",
              "  pm.expect(body.tamper_events.length).to.be.above(0);",
              "  pm.expect(body.alert_deliveries.length).to.be.above(2);",
              "  pm.expect(body.health.score).to.be.above(0);",
              "  pm.expect(body.archive.provider).to.eql('s3');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Alert Deliveries Include Email Push Dashboard",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-TraceDeck-API-Key", "value": "{{apiKey}}" },
          { "key": "X-TraceDeck-Tenant-ID", "value": "family-varadha" }
        ],
        "url": "{{baseUrl}}/api/v1/devices/postman-phase16-device/alert-deliveries"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('email, push, and dashboard delivery routes are visible', function () {",
              "  pm.response.to.have.status(200);",
              "  const items = pm.response.json().items;",
              "  pm.expect(items.some((item) => item.channel === 'email' && item.status === 'delivered')).to.eql(true);",
              "  pm.expect(items.some((item) => item.channel === 'push' && item.status === 'retrying')).to.eql(true);",
              "  pm.expect(items.some((item) => item.channel === 'dashboard' && item.status === 'delivered')).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Weekly Report Mail Packaging",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-TraceDeck-API-Key", "value": "{{apiKey}}" },
          { "key": "X-TraceDeck-Tenant-ID", "value": "family-varadha" }
        ],
        "url": "{{baseUrl}}/api/v1/devices/postman-phase16-device/reports/weekly"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('weekly report is ready for email and PDF delivery', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.email_ready).to.eql(true);",
              "  pm.expect(body.pdf_ready).to.eql(true);",
              "  pm.expect(body.email_subject.length).to.be.above(0);",
              "  pm.expect(body.email_preview.length).to.be.above(0);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Dashboard Contains Monetisation Panels",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('dashboard exposes notification, mail, push, and paid packaging panels', function () {",
              "  pm.response.to.have.status(200);",
              "  const html = pm.response.text();",
              "  pm.expect(html).to.include('Anomaly Notification Inbox');",
              "  pm.expect(html).to.include('Mail Delivery Center');",
              "  pm.expect(html).to.include('Push Routing');",
              "  pm.expect(html).to.include('Email SLA');",
              "  pm.expect(html).to.include('Paid Trigger');",
              "  pm.expect(html).to.include('Endpoint productivity and risk observability');",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:18080"
    },
    {
      "key": "apiKey",
      "value": "phase16-local-secret"
    }
  ]
}
