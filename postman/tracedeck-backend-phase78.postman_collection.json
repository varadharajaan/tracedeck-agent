{
  "info": {
    "name": "TraceDeck Backend Phase 78",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('health is ok', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Dashboard Provider Setup UI",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('dashboard contains Phase 78 provider setup markers', function () {",
              "  pm.response.to.have.status(200);",
              "  const html = pm.response.text();",
              "  pm.expect(html).to.include('Notification Provider Setup Center');",
              "  pm.expect(html).to.include('Provider Channel Setup');",
              "  pm.expect(html).to.include('Provider Setup Checklist');",
              "  pm.expect(html).to.include('Provider Setup Actions');",
              "  pm.expect(html).to.include('data-jump-target=\"notification-provider-setup-section\"');",
              "  pm.expect(html).to.include('nav-provider-setup-meta');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Notification Provider Setup API",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/tenants/family-varadha/notification-provider-setup"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('provider setup separates configured from provider confirmed', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.summary.routes_total).to.eql(3);",
              "  pm.expect(body.summary.channels_total).to.eql(3);",
              "  pm.expect(body.channels.length).to.eql(3);",
              "  pm.expect(body.summary.demo_only).to.be.at.least(1);",
              "  pm.expect(body.summary.retrying).to.be.at.least(1);",
              "  pm.expect(body.summary.email_provider_confirmed).to.eql(false);",
              "  pm.expect(body.summary.push_provider_confirmed).to.eql(false);",
              "  pm.expect(body.summary.buyer_ready).to.eql(false);",
              "  pm.expect(body.checklist.length).to.be.at.least(3);",
              "  pm.expect(body.actions.length).to.be.at.least(1);",
              "  pm.expect(body.privacy_boundary).to.include('metadata-only');",
              "  pm.expect(body.privacy_boundary).to.include('no provider secrets');",
              "  const serialized = JSON.stringify(body).toLowerCase();",
              "  ['smtp_password', 'provider_secret', 'push_endpoint', 'screenshot_bytes', 'raw_url', 'page_title', 'alert_body', 'raw_provider_payload', 'password_value'].forEach(function (marker) {",
              "    pm.expect(serialized).to.not.include(marker);",
              "  });",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
