{
  "info": {
    "name": "TraceDeck Backend Phase 82",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('health is ok', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Dashboard Product Polish",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('dashboard uses Phase 82 polished admin shell', function () {",
              "  pm.response.to.have.status(200);",
              "  const html = pm.response.text();",
              "  [",
              "    'Phase 82 product polish',",
              "    '<span class=\"brand-mark\" aria-hidden=\"true\"><span></span><span></span><span></span></span>',",
              "    'class=\"command-label\">Deployment Readiness</span>',",
              "    'class=\"command-label\">Customer Control Room</span>',",
              "    'class=\"command-label\">Delivery Assurance</span>',",
              "    'class=\"command-meta\">waiting</span>',",
              "    'body.theme-dark',",
              "    'server-status-light'",
              "  ].forEach(function (marker) { pm.expect(html).to.include(marker); });",
              "  [",
              "    '<span class=\"brand-mark\" aria-hidden=\"true\">TD</span>',",
              "    'Browser{',",
              "    'Center{',",
              "    '[B]',",
              "    '{C}',",
              "    'Rev Ops',",
              "    'Notif Rev',",
              "    'Notify Pro'",
              "  ].forEach(function (marker) { pm.expect(html).to.not.include(marker); });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Browser Activity Product Polish",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/browser-activity"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('browser activity page uses polished admin shell', function () {",
              "  pm.response.to.have.status(200);",
              "  const html = pm.response.text();",
              "  [",
              "    'Browser Viewer',",
              "    'Browser Activity Viewer',",
              "    'Phase 82 product polish',",
              "    '<span class=\"brand-mark\" aria-hidden=\"true\"><span></span><span></span><span></span></span>',",
              "    'Chrome, Brave, and Edge',",
              "    'server-status-light'",
              "  ].forEach(function (marker) { pm.expect(html).to.include(marker); });",
              "  [",
              "    '<span class=\"brand-mark\" aria-hidden=\"true\">TD</span>',",
              "    'Browser{',",
              "    'Center{',",
              "    '[B]',",
              "    '{C}',",
              "    'raw_url',",
              "    'page_title'",
              "  ].forEach(function (marker) { pm.expect(html).to.not.include(marker); });",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
