{
  "info": {
    "name": "TraceDeck Backend Phase 31",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": { "method": "GET", "url": "{{baseUrl}}/health" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('health is ok', function () { pm.response.to.have.status(200); pm.expect(pm.response.json().status).to.eql('ok'); });"
      ] } }]
    },
    {
      "name": "Dashboard Contains Buyer Assurance Wall",
      "request": { "method": "GET", "url": "{{baseUrl}}/" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('dashboard has monetisable assurance and sync panels', function () {",
        "  pm.response.to.have.status(200);",
        "  const html = pm.response.text();",
        "  pm.expect(html).to.include('Buyer Assurance Wall');",
        "  pm.expect(html).to.include('Offline Replay Health');",
        "  pm.expect(html).to.include('product-assurance-push');",
        "  pm.expect(html).to.include('sync-health-device-list');",
        "});"
      ] } }]
    },
    {
      "name": "Ingest Sync Health Events",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/devices/newman-sync-device/telemetry-events",
        "body": {
          "mode": "raw",
          "raw": "{\"tenant_id\":\"family-varadha\",\"device_id\":\"newman-sync-device\",\"host_name\":\"newman-sync-host\",\"profile\":\"ai-btech-student\",\"os_name\":\"windows\",\"events\":[{\"id\":\"local-event-31\",\"type\":\"process.observed\",\"source\":\"collector.process\",\"observed_at\":\"2026-06-12T08:00:00Z\",\"app_name\":\"Code.exe\",\"process_id\":301,\"path_hash\":\"hash-only\",\"metadata\":{\"category\":\"coding\"}},{\"id\":\"local-event-32\",\"type\":\"browser.summary\",\"source\":\"collector.browser.history\",\"observed_at\":\"2026-06-12T08:01:00Z\",\"metadata\":{\"domain\":\"youtube.com\",\"category\":\"study\"}},{\"id\":\"local-event-33\",\"type\":\"device.health\",\"source\":\"collector.device.health\",\"observed_at\":\"2026-06-12T08:02:00Z\",\"metadata\":{\"battery\":\"ok\"}}]}"
        }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('sync health events are accepted', function () {",
        "  pm.response.to.have.status(202);",
        "  const body = pm.response.json();",
        "  pm.expect(body.accepted_events).to.eql(3);",
        "  pm.expect(body.backend_visible_host).to.eql(true);",
        "});"
      ] } }]
    },
    {
      "name": "Tenant Sync Health",
      "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/tenants/family-varadha/sync-health" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('tenant sync health exposes replay and source proof', function () {",
        "  pm.response.to.have.status(200);",
        "  const body = pm.response.json();",
        "  pm.expect(body.hosts_reporting).to.be.at.least(1);",
        "  pm.expect(body.stored_events).to.be.at.least(3);",
        "  pm.expect(body.last_local_event_id).to.be.at.least(33);",
        "  pm.expect(body.offline_replay_ready).to.eql(true);",
        "  pm.expect(body.privacy_boundary).to.include('metadata-only');",
        "  const device = body.devices.find((item) => item.device_id === 'newman-sync-device');",
        "  pm.expect(device.process_events).to.eql(1);",
        "  pm.expect(device.browser_events).to.eql(1);",
        "  pm.expect(device.health_events).to.eql(1);",
        "});"
      ] } }]
    },
    {
      "name": "Tenant Monetisation Still Has Notification Proof",
      "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/tenants/family-varadha/monetization-summary" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('monetisation summary keeps email and push proof', function () {",
        "  pm.response.to.have.status(200);",
        "  const body = pm.response.json();",
        "  pm.expect(body.notification_promise.email).to.be.a('string').that.is.not.empty;",
        "  pm.expect(body.notification_promise.push).to.be.a('string').that.is.not.empty;",
        "  pm.expect(body.notification_routes.map((item) => item.channel)).to.include('email');",
        "  pm.expect(body.notification_routes.map((item) => item.channel)).to.include('push');",
        "});"
      ] } }]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:18080" }
  ]
}
