{
  "info": {
    "name": "TraceDeck Backend Phase 38",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": { "method": "GET", "url": "{{baseUrl}}/health" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('health is ok', function () { pm.response.to.have.status(200); pm.expect(pm.response.json().status).to.eql('ok'); });"
      ] } }]
    },
    {
      "name": "Dashboard Contains Commercial Control Room",
      "request": { "method": "GET", "url": "{{baseUrl}}/" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('dashboard has monetisation-grade commercial room', function () {",
        "  pm.response.to.have.status(200);",
        "  const html = pm.response.text();",
        "  pm.expect(html).to.include('Commercial Control Room');",
        "  pm.expect(html).to.include('Alert Delivery Evidence');",
        "  pm.expect(html).to.include('Customer Success Queue');",
        "  pm.expect(html).to.include('commercial-room-status');",
        "  pm.expect(html).to.include('commercial-delivery-list');",
        "  pm.expect(html).to.include('commercial-success-list');",
        "});"
      ] } }]
    },
    {
      "name": "Tenant Operations Back Commercial Proof",
      "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/tenants/family-varadha/operations-summary" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('tenant operations include anomaly, mail, push, and delivery proof', function () {",
        "  pm.response.to.have.status(200);",
        "  const body = pm.response.json();",
        "  pm.expect(body.hosts_total).to.be.above(0);",
        "  pm.expect(body.open_anomalies).to.be.above(0);",
        "  pm.expect(body.delivery_total).to.be.above(0);",
        "  pm.expect(body.email_delivered).to.be.above(0);",
        "  pm.expect(body.last_email).to.be.an('object');",
        "});"
      ] } }]
    },
    {
      "name": "Tenant Monetisation Backs Success Queue",
      "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/tenants/family-varadha/monetization-summary" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('monetisation summary backs commercial cockpit', function () {",
        "  pm.response.to.have.status(200);",
        "  const body = pm.response.json();",
        "  pm.expect(body.readiness_score).to.be.above(0);",
        "  pm.expect(body.notification_score).to.be.above(0);",
        "  pm.expect(body.trust_score).to.be.above(0);",
        "  pm.expect(body.conversion_actions.length).to.be.above(0);",
        "  pm.expect(body.notification_promise.email).to.be.a('string');",
        "  pm.expect(body.notification_promise.push).to.be.a('string');",
        "});"
      ] } }]
    },
    {
      "name": "Notification Routes Cover Paid Channels",
      "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/tenants/family-varadha/notification-routes" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('notification route registry covers commercial channels', function () {",
        "  pm.response.to.have.status(200);",
        "  const channels = pm.response.json().items.map((item) => item.channel);",
        "  pm.expect(channels).to.include('email');",
        "  pm.expect(channels).to.include('push');",
        "  pm.expect(channels).to.include('dashboard');",
        "});"
      ] } }]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:18080" }
  ]
}
