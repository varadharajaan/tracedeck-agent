{
  "info": {
    "name": "TraceDeck Backend Phase 6",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('health is ok', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Version",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/version"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('version exposes backend service', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().service).to.eql('tracedeck-backend');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Plans",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/plans"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('plans include Family Pro', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.items.some((plan) => plan.id === 'family_pro')).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Roles",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/roles"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('roles include parent', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.items.some((role) => role.id === 'parent')).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Retention Tiers",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/retention-tiers"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('retention tiers include family archive', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.items.some((tier) => tier.id === 'family_cloud_90_365_archive')).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Tenant",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"tenant_id\":\"family-varadha\",\"name\":\"Family Varadha\",\"plan_id\":\"family_pro\",\"retention_tier_id\":\"family_cloud_90_365_archive\",\"primary_profile\":\"ai-btech-student\"}"
        },
        "url": "{{baseUrl}}/api/v1/tenants"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('tenant created', function () {",
              "  pm.response.to.have.status(201);",
              "  const body = pm.response.json();",
              "  pm.expect(body.tenant_id).to.eql('family-varadha');",
              "  pm.expect(body.plan_id).to.eql('family_pro');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "List Tenants",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/tenants"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('tenant list includes family', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.items.some((tenant) => tenant.tenant_id === 'family-varadha')).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Tenant",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/tenants/family-varadha"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('tenant lookup succeeds', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().tenant_id).to.eql('family-varadha');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Tenant Audit Events",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/tenants/family-varadha/audit-events"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('tenant audit event exists', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.count).to.be.above(0);",
              "  pm.expect(body.items[0].action).to.eql('tenant.created');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "All Audit Events",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/audit-events"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('global audit event list works', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().count).to.be.above(0);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Enroll Device",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"tenant_id\":\"family-varadha\",\"device_id\":\"postman-device-001\",\"host_name\":\"postman-host\",\"profile\":\"ai-btech-student\",\"os_name\":\"windows\"}"
        },
        "url": "{{baseUrl}}/api/v1/devices/enroll"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('device enrolled', function () {",
              "  pm.response.to.have.status(201);",
              "  pm.expect(pm.response.json().device_id).to.eql('postman-device-001');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "List Devices",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/devices"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('device list includes enrollment', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.items.some((device) => device.device_id === 'postman-device-001')).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Policy Templates",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/policy-templates"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('policy templates exist', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().count).to.be.above(0);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Archive Status",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/archive/status"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('archive status is s3 backed', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().provider).to.eql('s3');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('dashboard is served', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.text()).to.include('TraceDeck');",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:18080"
    }
  ]
}
