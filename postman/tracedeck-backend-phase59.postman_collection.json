{
  "info": {
    "name": "TraceDeck Backend Phase 59",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('health is ok', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Dashboard Has Push Activation Center",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('dashboard contains push activation markers', function () {",
              "  pm.response.to.have.status(200);",
              "  const html = pm.response.text();",
              "  pm.expect(html).to.include('Push Activation Center');",
              "  pm.expect(html).to.include('Push Route Proof');",
              "  pm.expect(html).to.include('Anomaly Push And Mail Scenarios');",
              "  pm.expect(html).to.include('Push Owner Actions');",
              "  pm.expect(html).to.include('Push Privacy Guard');",
              "  pm.expect(html).to.include('data-jump-target=\"push-activation-section\"');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Tenant Push Activation Center",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/tenants/family-varadha/push-activation-center"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('push activation center exposes monetisable delivery proof', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.summary.activation_score).to.be.above(0);",
              "  pm.expect(body.summary.notification_score).to.be.above(0);",
              "  pm.expect(body.summary.mail_delivered).to.be.above(0);",
              "  pm.expect(body.summary.dashboard_delivered).to.be.above(0);",
              "  pm.expect(body.summary.push_routes_total).to.be.above(0);",
              "  pm.expect(body.summary.alert_rules_using_push).to.be.above(0);",
              "  pm.expect(body.summary.alerts_with_push).to.be.above(0);",
              "  pm.expect(body.summary.owner_next_step).to.be.a('string').and.not.empty;",
              "  pm.expect(body.routes.length).to.be.at.least(1);",
              "  pm.expect(body.scenarios.length).to.be.at.least(3);",
              "  pm.expect(body.actions.length).to.be.at.least(1);",
              "  pm.expect(body.routes[0].provider).to.eql('web_push');",
              "  pm.expect(body.routes[0].subscription_label).to.be.a('string').and.not.empty;",
              "  pm.expect(body.routes[0].endpoint_storage).to.include('raw push endpoint is not stored');",
              "  pm.expect(body.scenarios[0].channels.length).to.be.above(0);",
              "  pm.expect(body.privacy_boundary).to.include('metadata-only');",
              "  pm.expect(body.privacy_boundary).to.include('no push endpoints');",
              "  pm.expect(body.privacy_boundary).to.include('no passwords');",
              "  const serialized = JSON.stringify(body).toLowerCase();",
              "  ['smtp_password', 'provider_secret', 'push_endpoint', 'screenshot_bytes', 'raw_url', 'page_title', 'alert_body', 'card_number', 'cvv', 'payment_token'].forEach(function (marker) {",
              "    pm.expect(serialized).to.not.include(marker);",
              "  });",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
