{
  "info": {
    "name": "TraceDeck Backend Phase 33",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": { "method": "GET", "url": "{{baseUrl}}/health" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('health is ok', function () { pm.response.to.have.status(200); pm.expect(pm.response.json().status).to.eql('ok'); });"
      ] } }]
    },
    {
      "name": "Dashboard Contains Monetisation Views",
      "request": { "method": "GET", "url": "{{baseUrl}}/" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('dashboard has monetisation command panels', function () {",
        "  pm.response.to.have.status(200);",
        "  const html = pm.response.text();",
        "  pm.expect(html).to.include('Monetisation Command Views');",
        "  pm.expect(html).to.include('Notification Monetisation Proof');",
        "  pm.expect(html).to.include('activity-view-list');",
        "});"
      ] } }]
    },
    {
      "name": "Seeded Tenant Activity Views",
      "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/tenants/family-varadha/activity-views" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('seeded command views exist', function () {",
        "  pm.response.to.have.status(200);",
        "  const body = pm.response.json();",
        "  pm.expect(body.count).to.eql(4);",
        "  pm.expect(body.items.map((item) => item.id)).to.include('high-risk-open');",
        "  pm.expect(body.items.map((item) => item.id)).to.include('email-proof');",
        "  pm.expect(body.items.map((item) => item.id)).to.include('push-retry');",
        "  pm.expect(body.items.map((item) => item.id)).to.include('sync-proof');",
        "});"
      ] } }]
    },
    {
      "name": "Create Business Command View",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/tenants/family-varadha/activity-views",
        "body": {
          "mode": "raw",
          "raw": "{\"name\":\"Business dashboard misses\",\"description\":\"Paid demo view for failed dashboard delivery proof.\",\"paid_tier\":\"business\",\"sort_order\":9,\"filter\":{\"kind\":\"delivery\",\"channel\":\"dashboard\",\"status\":\"failed\",\"limit\":10}}"
        }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('business command view is created', function () {",
        "  pm.response.to.have.status(201);",
        "  const body = pm.response.json();",
        "  pm.expect(body.paid_tier).to.eql('business');",
        "  pm.expect(body.filter.channel).to.eql('dashboard');",
        "});"
      ] } }]
    },
    {
      "name": "Reject Unknown Activity View Filter",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/tenants/family-varadha/activity-views",
        "body": {
          "mode": "raw",
          "raw": "{\"name\":\"Bad view\",\"filter\":{\"kind\":\"random\"}}"
        }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('unknown filter is rejected', function () {",
        "  pm.response.to.have.status(400);",
        "  pm.expect(pm.response.json().error).to.include('filter.kind is unknown');",
        "});"
      ] } }]
    },
    {
      "name": "Activity View Audit Proof",
      "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/tenants/family-varadha/audit-events" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('activity view creation is audited', function () {",
        "  pm.response.to.have.status(200);",
        "  const body = pm.response.json();",
        "  pm.expect(body.items.some((item) => item.action === 'activity_view.created')).to.eql(true);",
        "});"
      ] } }]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:18080" }
  ]
}
