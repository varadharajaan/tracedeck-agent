{
  "info": {
    "name": "TraceDeck Backend Phase 63",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('health is ok', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Dashboard Has Tenant Onboarding Center",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('dashboard contains tenant onboarding markers', function () {",
              "  pm.response.to.have.status(200);",
              "  const html = pm.response.text();",
              "  pm.expect(html).to.include('Tenant Onboarding Center');",
              "  pm.expect(html).to.include('Setup Checklist');",
              "  pm.expect(html).to.include('Role Handoff');",
              "  pm.expect(html).to.include('Onboarding Proof');",
              "  pm.expect(html).to.include('Onboarding Owner Actions');",
              "  pm.expect(html).to.include('data-jump-target=\"onboarding-center-section\"');",
              "  pm.expect(html).to.include('onboarding-kpi-notifications');",
              "  pm.expect(html).to.include('onboarding-kpi-autostart');",
              "  pm.expect(html).to.include('onboarding-kpi-archive');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Tenant Onboarding Center API",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/tenants/family-varadha/onboarding-center"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('onboarding center is typed and metadata-only', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.summary.readiness_score).to.be.above(0);",
              "  pm.expect(body.summary.setup_steps_total).to.be.at.least(8);",
              "  pm.expect(body.summary.hosts_total).to.be.at.least(1);",
              "  pm.expect(body.summary.roles_total).to.be.at.least(4);",
              "  pm.expect(body.summary.owner_next_step).to.be.a('string').and.not.empty;",
              "  pm.expect(body.steps.length).to.be.at.least(8);",
              "  pm.expect(body.roles.length).to.be.at.least(4);",
              "  pm.expect(body.proof.length).to.be.at.least(6);",
              "  pm.expect(body.actions.length).to.be.at.least(1);",
              "  ['agent-install', 'autostart', 'notification-policy', 'mail-push-proof', 'archive-retention', 'role-dashboards', 'package-readiness', 'privacy-guard'].forEach(function (id) {",
              "    pm.expect(body.steps.map(function (step) { return step.id; })).to.include(id);",
              "  });",
              "  pm.expect(body.privacy_boundary).to.include('metadata-only');",
              "  pm.expect(body.privacy_boundary).to.include('no passwords');",
              "  pm.expect(body.privacy_boundary).to.include('no screenshots');",
              "  pm.expect(body.privacy_boundary).to.include('push endpoints');",
              "  const serialized = JSON.stringify(body).toLowerCase();",
              "  ['smtp_password', 'provider_secret', 'push_endpoint_url', 'screenshot_bytes', 'raw_url', 'page_title', 'alert_body', 'card_number', 'cvv', 'payment_token'].forEach(function (marker) {",
              "    pm.expect(serialized).to.not.include(marker);",
              "  });",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
