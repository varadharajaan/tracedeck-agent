{
  "info": {
    "name": "TraceDeck Cloud Frontend Phase 72",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Lambda Health",
      "request": {
        "method": "GET",
        "url": "{{lambdaUrl}}/api/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('lambda health is ok', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.status).to.eql('ok');",
              "  pm.expect(body.service).to.eql('tracedeck-lambda-frontend');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Cloud Admin HTML",
      "request": {
        "method": "GET",
        "url": "{{lambdaUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('cloud admin exposes controls', function () {",
              "  pm.response.to.have.status(200);",
              "  const html = pm.response.text();",
              "  pm.expect(html).to.include('TraceDeck Cloud Admin');",
              "  pm.expect(html).to.include('source-select');",
              "  pm.expect(html).to.include('Localhost 18080');",
              "  pm.expect(html).to.include('metric-hit');",
              "  pm.expect(html).to.include('metric-miss');",
              "  pm.expect(html).to.include('<th>Source</th>');",
              "  pm.expect(html).to.include('sourceBadge');",
              "  pm.expect(html).to.include('server-status');",
              "  pm.expect(html).to.include('theme-button');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "S3 Summary Refresh",
      "request": {
        "method": "GET",
        "url": "{{lambdaUrl}}/api/s3-summary?refresh=true"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('s3 summary reads uploaded metadata rows', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.status).to.eql('ok');",
              "  pm.expect(body.summary.objects).to.be.at.least(1);",
              "  pm.expect(body.summary.sampled_rows).to.be.at.least(5);",
              "  pm.expect(body.summary.study_safe).to.be.at.least(2);",
              "  pm.expect(body.summary.non_study_youtube).to.be.at.least(1);",
              "  pm.expect(body.browser_rows.length).to.be.at.least(5);",
              "  pm.expect(body.browser_rows[0].source_kind).to.be.a('string').and.not.empty;",
              "  pm.expect(body.browser_rows[0].evidence_scope).to.be.a('string').and.not.empty;",
              "  pm.expect(body.browser_rows[0].evidence_detail).to.be.a('string').and.not.empty;",
              "  const browsers = body.browsers.map(function (item) { return item.label; });",
              "  ['chrome', 'edge', 'brave'].forEach(function (name) { pm.expect(browsers).to.include(name); });",
              "  pm.expect(body.privacy_boundary).to.include('metadata-only');",
              "  const serialized = JSON.stringify(body).toLowerCase();",
              "  ['https://', 'http://', 'raw_url', 'page_title', 'password', 'cookie_value', 'token_value', 'screenshot', 'push_endpoint', 'provider_secret', 'keylogger'].forEach(function (marker) {",
              "    pm.expect(serialized).to.not.include(marker);",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "S3 Summary Cache Hit",
      "request": {
        "method": "GET",
        "url": "{{lambdaUrl}}/api/s3-summary"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('s3 summary second read uses cache', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.status).to.eql('ok');",
              "  pm.expect(body.cache.hit).to.eql(true);",
              "  pm.expect(body.cache.hit_percent).to.be.above(0);",
              "  pm.expect(body.summary.sampled_rows).to.be.at.least(5);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
