{
  "info": {
    "name": "TraceDeck Backend Phase 66",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('health is ok', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Dashboard Has Deployment Readiness Center",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('dashboard contains deployment readiness markers', function () {",
              "  pm.response.to.have.status(200);",
              "  const html = pm.response.text();",
              "  pm.expect(html).to.include('Deployment Readiness Center');",
              "  pm.expect(html).to.include('Platform Service Proof');",
              "  pm.expect(html).to.include('Service Manifest Proof');",
              "  pm.expect(html).to.include('Boot And Replay Proof');",
              "  pm.expect(html).to.include('Deployment Owner Actions');",
              "  pm.expect(html).to.include('data-jump-target=\"deployment-readiness-section\"');",
              "  pm.expect(html).to.include('deployment-kpi-liveboot');",
              "  pm.expect(html).to.include('deployment-kpi-autostart');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Tenant Deployment Readiness Center API",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/tenants/family-varadha/deployment-readiness-center"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('deployment readiness center is typed and metadata-only', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.summary.readiness_score).to.be.above(0);",
              "  pm.expect(body.summary.owner_next_step).to.be.a('string').and.not.empty;",
              "  pm.expect(body.summary.platforms_total).to.eql(3);",
              "  pm.expect(body.summary.manifests_total).to.eql(3);",
              "  pm.expect(body.summary.hosts_total).to.be.at.least(1);",
              "  pm.expect(body.summary.live_boot_ready).to.be.a('boolean');",
              "  pm.expect(body.summary.offline_replay_ready).to.be.a('boolean');",
              "  pm.expect(body.platforms.length).to.eql(3);",
              "  pm.expect(body.manifests.length).to.eql(3);",
              "  pm.expect(body.proof.length).to.be.at.least(5);",
              "  pm.expect(body.actions.length).to.be.at.least(4);",
              "  ['windows', 'darwin', 'linux'].forEach(function (platform) {",
              "    pm.expect(body.platforms.map(function (item) { return item.platform; })).to.include(platform);",
              "  });",
              "  ['task_scheduler', 'launchd', 'systemd'].forEach(function (manager) {",
              "    pm.expect(body.platforms.map(function (item) { return item.service_manager; })).to.include(manager);",
              "  });",
              "  ['windows-task', 'macos-launchd', 'linux-systemd'].forEach(function (id) {",
              "    pm.expect(body.manifests.map(function (item) { return item.id; })).to.include(id);",
              "  });",
              "  ['live-boot', 'offline-replay', 'windows-task-scheduler', 'macos-linux-services'].forEach(function (id) {",
              "    pm.expect(body.proof.map(function (item) { return item.id; })).to.include(id);",
              "  });",
              "  pm.expect(body.privacy_boundary).to.include('metadata-only');",
              "  pm.expect(body.privacy_boundary).to.include('no passwords');",
              "  pm.expect(body.privacy_boundary).to.include('no screenshots');",
              "  pm.expect(body.privacy_boundary).to.include('hidden collection bypasses');",
              "  const serialized = JSON.stringify(body).toLowerCase();",
              "  ['smtp_password', 'provider_secret', 'push_endpoint', 'screenshot_bytes', 'raw_url', 'page_title', 'alert_body', 'card_number', 'cvv', 'payment_token', 'keylogger'].forEach(function (marker) {",
              "    pm.expect(serialized).to.not.include(marker);",
              "  });",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
