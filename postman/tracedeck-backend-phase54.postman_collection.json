{
  "info": {
    "name": "TraceDeck Backend Phase 54",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('health is ok', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Dashboard Has Notification Revenue Cockpit",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('dashboard contains notification revenue markers', function () {",
              "  pm.response.to.have.status(200);",
              "  var body = pm.response.text();",
              "  ['Notification Revenue Cockpit', 'notification-revenue-section', 'Revenue KPI Proof', 'Anomaly Delivery Scenarios', 'Channel Proof Matrix', 'Upgrade Action Levers', 'data-jump-target=\"notification-revenue-section\"'].forEach(function (marker) {",
              "    pm.expect(body).to.include(marker);",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Tenant Notification Revenue Cockpit",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/tenants/family-varadha/notification-revenue-cockpit"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('notification revenue cockpit exposes monetisable notification proof', function () {",
              "  pm.response.to.have.status(200);",
              "  var json = pm.response.json();",
              "  pm.expect(json.summary.revenue_readiness).to.be.above(0);",
              "  pm.expect(json.summary.notification_score).to.be.above(0);",
              "  pm.expect(json.summary.alert_sla_ready).to.be.above(0);",
              "  pm.expect(json.summary.recommended_paid_package).to.be.a('string').and.not.empty;",
              "  pm.expect(json.summary.next_best_action).to.be.a('string').and.not.empty;",
              "  pm.expect(json.summary.email_delivered).to.be.above(0);",
              "  pm.expect(json.summary.dashboard_delivered).to.be.above(0);",
              "  pm.expect(json.kpis.length).to.be.at.least(6);",
              "  pm.expect(json.channels.length).to.be.at.least(3);",
              "  pm.expect(json.scenarios.length).to.be.at.least(4);",
              "  pm.expect(json.actions.length).to.be.at.least(1);",
              "  pm.expect(json.channels.some(function (item) { return item.channel === 'push' && item.business_value && item.paid_tier; })).to.eql(true);",
              "  pm.expect(json.scenarios.some(function (item) { return item.trigger === 'non_study_youtube' && item.channels.length >= 2; })).to.eql(true);",
              "  pm.expect(json.privacy_boundary).to.include('metadata-only');",
              "  pm.expect(json.privacy_boundary).to.include('no passwords');",
              "  pm.expect(json.privacy_boundary).to.include('screenshots');",
              "  var serialized = JSON.stringify(json).toLowerCase();",
              "  ['smtp_password', 'provider_secret', 'screenshot_bytes', 'raw_url', 'page_title', 'alert_body'].forEach(function (marker) {",
              "    pm.expect(serialized).to.not.include(marker);",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Tenant Executive Console Still Present",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/tenants/family-varadha/executive-console"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('executive console still exposes paid first screen', function () {",
              "  pm.response.to.have.status(200);",
              "  var json = pm.response.json();",
              "  pm.expect(json.summary.readiness_score).to.be.above(0);",
              "  pm.expect(json.deliveries.some(function (item) { return item.channel === 'push' && item.status; })).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
