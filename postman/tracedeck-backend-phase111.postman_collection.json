{
  "info": {
    "name": "TraceDeck Phase 111 Software Inventory Collector",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('health is ok and no-store', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "  pm.expect(pm.response.headers.get('Cache-Control')).to.eql('no-store, no-cache, must-revalidate, max-age=0');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Software Tenant",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/v1/tenants",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tenant_id\": \"family-varadha\",\n  \"name\": \"Family Varadha\",\n  \"plan_id\": \"family_pro\",\n  \"retention_tier_id\": \"family_cloud_90_365_archive\",\n  \"primary_profile\": \"ai-btech-student\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('tenant exists', function () {",
              "  pm.response.to.have.status(201);",
              "  pm.expect(pm.response.json().tenant_id).to.eql('family-varadha');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Enroll Software Device",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/v1/devices/enroll",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tenant_id\": \"family-varadha\",\n  \"device_id\": \"phase111-software-device\",\n  \"host_name\": \"phase111-software-host\",\n  \"profile\": \"ai_btech_student\",\n  \"os_name\": \"windows\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('device enrolled', function () {",
              "  pm.response.to.have.status(201);",
              "  pm.expect(pm.response.json().device_id).to.eql('phase111-software-device');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Ingest Software Install Event",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/v1/devices/phase111-software-device/telemetry-events",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tenant_id\": \"family-varadha\",\n  \"device_id\": \"phase111-software-device\",\n  \"host_name\": \"phase111-software-host\",\n  \"profile\": \"ai_btech_student\",\n  \"os_name\": \"windows\",\n  \"events\": [\n    {\n      \"id\": \"phase111-software-event-1\",\n      \"type\": \"software.installed\",\n      \"source\": \"collector.software.inventory\",\n      \"observed_at\": \"{{$isoTimestamp}}\",\n      \"tenant_id\": \"family-varadha\",\n      \"device_id\": \"phase111-software-device\",\n      \"host_name\": \"phase111-software-host\",\n      \"app_name\": \"qbittorrent.exe\",\n      \"path_hash\": \"sha256:metadata-only-software-fixture\",\n      \"metadata\": {\n        \"profile\": \"ai-btech-student\",\n        \"operating_system\": \"windows\",\n        \"software_change\": \"installed\",\n        \"software_inventory_mode\": \"metadata_only\",\n        \"software_name_hash\": \"sha256:name-fixture\",\n        \"software_source\": \"windows_registry_uninstall\",\n        \"software_snapshot_id\": \"sha256:snapshot-fixture\",\n        \"path_mode\": \"none\",\n        \"software_risk_category\": \"torrent_client\",\n        \"software_risk_reason\": \"torrent client process observed\"\n      }\n    }\n  ]\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('software install event accepted', function () {",
              "  pm.response.to.have.status(202);",
              "  const body = pm.response.json();",
              "  pm.expect(body.accepted_events).to.eql(1);",
              "  pm.expect(body.privacy_boundary).to.include('metadata-only');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Telemetry Status Software Metadata",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/devices/phase111-software-device/telemetry-status"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('software telemetry is metadata-only', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.headers.get('Cache-Control')).to.eql('no-store, no-cache, must-revalidate, max-age=0');",
              "  const body = pm.response.json();",
              "  pm.expect(body.stored_events).to.be.at.least(1);",
              "  pm.expect(body.counts_by_type['software.installed']).to.eql(1);",
              "  pm.expect(body.counts_by_source['collector.software.inventory']).to.eql(1);",
              "  const event = (body.recent_events || []).find((item) => item.type === 'software.installed');",
              "  pm.expect(event).to.be.an('object');",
              "  pm.expect(event.metadata.software_inventory_mode).to.eql('metadata_only');",
              "  pm.expect(event.metadata.path_mode).to.eql('none');",
              "  const serialized = JSON.stringify(body.recent_events || []).toLowerCase();",
              "  ['password', 'screenshot', 'raw_url', 'page_title', 'window_title', 'cookie', 'token', 'provider_secret', 'alert_body', 'install_location', 'c:\\\\users'].forEach((marker) => {",
              "    pm.expect(serialized).to.not.include(marker);",
              "  });",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
