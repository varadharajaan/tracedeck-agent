{
  "info": {
    "name": "TraceDeck Backend Phase 34",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": { "method": "GET", "url": "{{baseUrl}}/health" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('health is ok', function () { pm.response.to.have.status(200); pm.expect(pm.response.json().status).to.eql('ok'); });"
      ] } }]
    },
    {
      "name": "Dashboard Contains Local Auth Panel",
      "request": { "method": "GET", "url": "{{baseUrl}}/" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('dashboard has session auth wiring and no embedded key', function () {",
        "  pm.response.to.have.status(200);",
        "  const html = pm.response.text();",
        "  pm.expect(html).to.include('Local Dashboard Access');",
        "  pm.expect(html).to.include('sessionStorage');",
        "  pm.expect(html).to.include('tracedeck.dashboard.apiKey');",
        "  pm.expect(html).to.include('X-TraceDeck-API-Key');",
        "  pm.expect(html).to.not.include(pm.environment.get('apiKey'));",
        "});"
      ] } }]
    },
    {
      "name": "Protected Devices Rejects Missing Key",
      "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/devices" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('devices API requires key', function () {",
        "  pm.response.to.have.status(401);",
        "  pm.expect(pm.response.json().error).to.include('api key is required');",
        "});"
      ] } }]
    },
    {
      "name": "Create Tenant With Dashboard Headers",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-TraceDeck-API-Key", "value": "{{apiKey}}" },
          { "key": "X-TraceDeck-Tenant-ID", "value": "family-varadha" },
          { "key": "X-TraceDeck-Actor-ID", "value": "phase34-newman" }
        ],
        "body": { "mode": "raw", "raw": "{\"tenant_id\":\"family-varadha\",\"name\":\"Family Varadha\",\"plan_id\":\"family_pro\",\"retention_tier_id\":\"family_cloud_90_365_archive\",\"primary_profile\":\"ai-btech-student\"}" },
        "url": "{{baseUrl}}/api/v1/tenants"
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('tenant created with dashboard headers', function () { pm.response.to.have.status(201); pm.expect(pm.response.json().tenant_id).to.eql('family-varadha'); });"
      ] } }]
    },
    {
      "name": "Enroll Device With Dashboard Headers",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-TraceDeck-API-Key", "value": "{{apiKey}}" },
          { "key": "X-TraceDeck-Tenant-ID", "value": "family-varadha" },
          { "key": "X-TraceDeck-Actor-ID", "value": "phase34-newman" }
        ],
        "body": { "mode": "raw", "raw": "{\"tenant_id\":\"family-varadha\",\"device_id\":\"phase34-newman-device\",\"host_name\":\"phase34-newman-host\",\"profile\":\"ai-btech-student\",\"os_name\":\"windows\"}" },
        "url": "{{baseUrl}}/api/v1/devices/enroll"
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('device enrolled with dashboard headers', function () { pm.response.to.have.status(201); pm.expect(pm.response.json().device_id).to.eql('phase34-newman-device'); });"
      ] } }]
    },
    {
      "name": "Authenticated Device List",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-TraceDeck-API-Key", "value": "{{apiKey}}" },
          { "key": "X-TraceDeck-Tenant-ID", "value": "family-varadha" },
          { "key": "X-TraceDeck-Actor-ID", "value": "phase34-newman" }
        ],
        "url": "{{baseUrl}}/api/v1/devices"
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('dashboard headers unlock tenant device list', function () {",
        "  pm.response.to.have.status(200);",
        "  const body = pm.response.json();",
        "  pm.expect(body.count).to.eql(1);",
        "  pm.expect(body.items[0].tenant_id).to.eql('family-varadha');",
        "});"
      ] } }]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:18080" },
    { "key": "apiKey", "value": "phase34-local-secret" }
  ]
}
