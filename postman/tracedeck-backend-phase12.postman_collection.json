{
  "info": {
    "name": "TraceDeck Backend Phase 12",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Without API Key",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('health is public', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Dashboard Shell Has Product Panels",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('dashboard contains monetisation-ready panels', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.text()).to.include('Device Health');",
              "  pm.expect(pm.response.text()).to.include('Notification Operations');",
              "  pm.expect(pm.response.text()).to.include('Product Packaging');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Devices Require API Key",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/devices"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('devices reject missing api key', function () {",
              "  pm.response.to.have.status(401);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Tenant With API Key",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-TraceDeck-API-Key",
            "value": "{{apiKey}}"
          },
          {
            "key": "X-TraceDeck-Tenant-ID",
            "value": "family-varadha"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"tenant_id\":\"family-varadha\",\"name\":\"Family Varadha\",\"plan_id\":\"family_pro\",\"retention_tier_id\":\"family_cloud_90_365_archive\",\"primary_profile\":\"ai-btech-student\"}"
        },
        "url": "{{baseUrl}}/api/v1/tenants"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('tenant created with api key', function () {",
              "  pm.response.to.have.status(201);",
              "  pm.expect(pm.response.json().tenant_id).to.eql('family-varadha');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Enroll Device With API Key",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-TraceDeck-API-Key",
            "value": "{{apiKey}}"
          },
          {
            "key": "X-TraceDeck-Tenant-ID",
            "value": "family-varadha"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"tenant_id\":\"family-varadha\",\"device_id\":\"postman-phase12-device\",\"host_name\":\"postman-phase12-host\",\"profile\":\"ai-btech-student\",\"os_name\":\"windows\"}"
        },
        "url": "{{baseUrl}}/api/v1/devices/enroll"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('device enrolled with api key', function () {",
              "  pm.response.to.have.status(201);",
              "  pm.expect(pm.response.json().device_id).to.eql('postman-phase12-device');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Host Overview Includes Device Health",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-TraceDeck-API-Key",
            "value": "{{apiKey}}"
          },
          {
            "key": "X-TraceDeck-Tenant-ID",
            "value": "family-varadha"
          }
        ],
        "url": "{{baseUrl}}/api/v1/devices/postman-phase12-device/overview"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('overview exposes health score and alert routes', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.device.device_id).to.eql('postman-phase12-device');",
              "  pm.expect(body.health.score).to.be.above(0);",
              "  pm.expect(body.alert_deliveries.some((item) => item.channel === 'email')).to.eql(true);",
              "  pm.expect(body.alert_deliveries.some((item) => item.channel === 'push')).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Standalone Device Health",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-TraceDeck-API-Key",
            "value": "{{apiKey}}"
          },
          {
            "key": "X-TraceDeck-Tenant-ID",
            "value": "family-varadha"
          }
        ],
        "url": "{{baseUrl}}/api/v1/devices/postman-phase12-device/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('device health is typed and scoped', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.device_id).to.eql('postman-phase12-device');",
              "  pm.expect(body.score).to.be.above(0);",
              "  pm.expect(body.status).to.be.oneOf(['healthy', 'watch', 'attention']);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Product Catalogs",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-TraceDeck-API-Key",
            "value": "{{apiKey}}"
          },
          {
            "key": "X-TraceDeck-Tenant-ID",
            "value": "family-varadha"
          }
        ],
        "url": "{{baseUrl}}/api/v1/policy-templates"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('policy template marketplace is available', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.count).to.be.above(0);",
              "  pm.expect(body.items.some((item) => item.id === 'ai-btech-student')).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Weekly Report Readiness",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-TraceDeck-API-Key",
            "value": "{{apiKey}}"
          },
          {
            "key": "X-TraceDeck-Tenant-ID",
            "value": "family-varadha"
          }
        ],
        "url": "{{baseUrl}}/api/v1/devices/postman-phase12-device/reports/weekly"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('weekly report endpoint is available for packaging panel', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().device_id).to.eql('postman-phase12-device');",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:18080"
    },
    {
      "key": "apiKey",
      "value": "phase12-local-secret"
    }
  ]
}
