{
  "info": {
    "name": "TraceDeck Backend Phase 88",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health No Store Header",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('health is ok and not cached', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "  pm.expect(pm.response.headers.get('Cache-Control')).to.eql('no-store, no-cache, must-revalidate, max-age=0');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Dashboard No Store Header",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('dashboard shell is no-store and product-grade', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.headers.get('Cache-Control')).to.eql('no-store, no-cache, must-revalidate, max-age=0');",
              "  const html = pm.response.text();",
              "  ['TraceDeck Console', 'Browser Evidence', 'Sync View', 'server-status-light', 'dashboard-page-nav'].forEach(function (marker) {",
              "    pm.expect(html).to.include(marker);",
              "  });",
              "  [/Browser\\s*\\{/, /Center\\s*\\{/, /\\[[BCTR]\\]/, /\\{[BCTR]\\}/, /\\bTD\\b/, /\\bRev Ops\\b/, /\\bNotif Rev\\b/, /\\bNotify Pro\\b/, /\\bNotifs\\b/].forEach(function (pattern) {",
              "    pm.expect(html).to.not.match(pattern);",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Browser Viewer No Store Header",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/browser-activity"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('browser viewer is no-store and source-backed', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.headers.get('Cache-Control')).to.eql('no-store, no-cache, must-revalidate, max-age=0');",
              "  const html = pm.response.text();",
              "  ['TraceDeck Browser Activity', 'Browser Viewer', 'Chrome, Brave, and Edge evidence', '<th>Source</th>', 'metadata-only guard'].forEach(function (marker) {",
              "    pm.expect(html).to.include(marker);",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Default Policy Evidence Is Live Only",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/devices/demo-study-laptop/policy-violations"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('default policy endpoint excludes seeded VLC evidence', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.headers.get('Cache-Control')).to.eql('no-store, no-cache, must-revalidate, max-age=0');",
              "  const body = pm.response.json();",
              "  const text = pm.response.text();",
              "  pm.expect(body.count).to.eql(0);",
              "  pm.expect(body.items).to.be.an('array').that.is.empty;",
              "  pm.expect(text).to.not.include('VLC media player');",
              "  pm.expect(text).to.not.include('demo_seed');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Opt In Demo Evidence Is Labelled",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/devices/demo-study-laptop/policy-violations?include_demo=true"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('demo evidence remains explicit and labelled', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.headers.get('Cache-Control')).to.eql('no-store, no-cache, must-revalidate, max-age=0');",
              "  const body = pm.response.json();",
              "  pm.expect(body.count).to.be.above(0);",
              "  pm.expect(body.items[0].source_kind).to.eql('demo_seed');",
              "  pm.expect(body.items[0].evidence_scope).to.eql('demo');",
              "  pm.expect(body.items[0].app_name).to.eql('VLC media player');",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:18080" }
  ]
}
