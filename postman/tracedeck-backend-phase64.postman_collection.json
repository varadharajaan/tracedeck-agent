{
  "info": {
    "name": "TraceDeck Backend Phase 64",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('health is ok', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Dashboard Has Customer Settings Center",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('dashboard contains customer settings markers', function () {",
              "  pm.response.to.have.status(200);",
              "  const html = pm.response.text();",
              "  pm.expect(html).to.include('Customer Settings Center');",
              "  pm.expect(html).to.include('Settings Matrix');",
              "  pm.expect(html).to.include('Plan And Retention Options');",
              "  pm.expect(html).to.include('Notification Channel Settings');",
              "  pm.expect(html).to.include('Settings Owner Actions');",
              "  pm.expect(html).to.include('data-jump-target=\"customer-settings-section\"');",
              "  pm.expect(html).to.include('settings-kpi-notifications');",
              "  pm.expect(html).to.include('settings-kpi-data-rights');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Tenant Customer Settings Center API",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/tenants/family-varadha/customer-settings-center"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('customer settings center is typed and metadata-only', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.summary.settings_score).to.be.above(0);",
              "  pm.expect(body.summary.settings_total).to.be.at.least(8);",
              "  pm.expect(body.summary.owner_next_step).to.be.a('string').and.not.empty;",
              "  pm.expect(body.settings.length).to.be.at.least(8);",
              "  pm.expect(body.plan_options.length).to.be.at.least(4);",
              "  pm.expect(body.retention_options.length).to.be.at.least(3);",
              "  pm.expect(body.channels.length).to.be.at.least(3);",
              "  pm.expect(body.actions.length).to.be.at.least(1);",
              "  ['plan', 'retention', 'notification-policy', 'mail-route', 'push-route', 'archive', 'autostart', 'role-views', 'privacy-data-rights'].forEach(function (id) {",
              "    pm.expect(body.settings.map(function (setting) { return setting.id; })).to.include(id);",
              "  });",
              "  pm.expect(body.privacy_boundary).to.include('metadata-only');",
              "  pm.expect(body.privacy_boundary).to.include('no passwords');",
              "  pm.expect(body.privacy_boundary).to.include('no screenshots');",
              "  pm.expect(body.privacy_boundary).to.include('push endpoints');",
              "  const serialized = JSON.stringify(body).toLowerCase();",
              "  ['smtp_password', 'provider_secret', 'push_endpoint_url', 'screenshot_bytes', 'raw_url', 'page_title', 'alert_body', 'card_number', 'cvv', 'payment_token'].forEach(function (marker) {",
              "    pm.expect(serialized).to.not.include(marker);",
              "  });",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
