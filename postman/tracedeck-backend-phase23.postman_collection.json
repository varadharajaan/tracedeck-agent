{
  "info": {
    "name": "TraceDeck Backend Phase 23",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": { "method": "GET", "url": "{{baseUrl}}/health" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('health is ok', function () { pm.response.to.have.status(200); pm.expect(pm.response.json().status).to.eql('ok'); });"
      ] } }]
    },
    {
      "name": "Create Tenant",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-TraceDeck-API-Key", "value": "{{apiKey}}" },
          { "key": "X-TraceDeck-Tenant-ID", "value": "family-varadha" }
        ],
        "body": { "mode": "raw", "raw": "{\"tenant_id\":\"family-varadha\",\"name\":\"Family Varadha\",\"plan_id\":\"family_pro\",\"retention_tier_id\":\"family_cloud_90_365_archive\",\"primary_profile\":\"ai-btech-student\"}" },
        "url": "{{baseUrl}}/api/v1/tenants"
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('tenant created', function () { pm.response.to.have.status(201); pm.expect(pm.response.json().tenant_id).to.eql('family-varadha'); });"
      ] } }]
    },
    {
      "name": "Enroll Device",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-TraceDeck-API-Key", "value": "{{apiKey}}" },
          { "key": "X-TraceDeck-Tenant-ID", "value": "family-varadha" }
        ],
        "body": { "mode": "raw", "raw": "{\"tenant_id\":\"family-varadha\",\"device_id\":\"phase23-device-001\",\"host_name\":\"phase23-study-laptop\",\"profile\":\"ai-btech-student\",\"os_name\":\"windows\"}" },
        "url": "{{baseUrl}}/api/v1/devices/enroll"
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('device enrolled', function () { pm.response.to.have.status(201); pm.expect(pm.response.json().device_id).to.eql('phase23-device-001'); });"
      ] } }]
    },
    {
      "name": "Tenant Operations Summary",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-TraceDeck-API-Key", "value": "{{apiKey}}" },
          { "key": "X-TraceDeck-Tenant-ID", "value": "family-varadha" }
        ],
        "url": "{{baseUrl}}/api/v1/tenants/family-varadha/operations-summary"
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('operations summary has monetisation dashboard data', function () {",
        "  pm.response.to.have.status(200);",
        "  const body = pm.response.json();",
        "  pm.expect(body.hosts_total).to.be.above(0);",
        "  pm.expect(body.delivery_total).to.be.above(0);",
        "  pm.expect(body.open_policy_violations).to.be.above(0);",
        "  pm.expect(body.last_email.channel).to.eql('email');",
        "  pm.expect(body.priority_signals.length).to.be.above(0);",
        "  pm.expect(body.upgrade_signals.length).to.be.above(0);",
        "});"
      ] } }]
    },
    {
      "name": "Dashboard Contains Customer Operations",
      "request": { "method": "GET", "url": "{{baseUrl}}/" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('dashboard exposes tenant operations panels', function () {",
        "  pm.response.to.have.status(200);",
        "  const html = pm.response.text();",
        "  pm.expect(html).to.include('Customer Operations Cockpit');",
        "  pm.expect(html).to.include('Escalation Workbench');",
        "  pm.expect(html).to.include('Notification Delivery Board');",
        "  pm.expect(html).to.include('Upgrade Proof Pack');",
        "});"
      ] } }]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:18080" },
    { "key": "apiKey", "value": "phase23-local-secret" }
  ]
}
