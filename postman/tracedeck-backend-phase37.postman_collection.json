{
  "info": {
    "name": "TraceDeck Backend Phase 37",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": { "method": "GET", "url": "{{baseUrl}}/health" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('health is ok', function () { pm.response.to.have.status(200); pm.expect(pm.response.json().status).to.eql('ok'); });"
      ] } }]
    },
    {
      "name": "Dashboard Contains Contract Guarded Revenue IDs",
      "request": { "method": "GET", "url": "{{baseUrl}}/" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('dashboard has contract guarded monetisation ids', function () {",
        "  pm.response.to.have.status(200);",
        "  const html = pm.response.text();",
        "  pm.expect(html).to.include('Revenue Command Center');",
        "  pm.expect(html).to.include('revenue-suite-status');",
        "  pm.expect(html).to.include('value-stack-score');",
        "  pm.expect(html).to.include('notification-rail-status');",
        "  pm.expect(html).to.include('rail-dashboard-title');",
        "  pm.expect(html).to.include('demo-checklist-list');",
        "});"
      ] } }]
    },
    {
      "name": "Tenant Monetisation Scores",
      "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/tenants/family-varadha/monetization-summary" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('monetisation scores still back dashboard contract', function () {",
        "  pm.response.to.have.status(200);",
        "  const body = pm.response.json();",
        "  pm.expect(body.readiness_score).to.be.above(0);",
        "  pm.expect(body.notification_score).to.be.above(0);",
        "  pm.expect(body.trust_score).to.be.above(0);",
        "});"
      ] } }]
    },
    {
      "name": "Notification Routes",
      "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/tenants/family-varadha/notification-routes" },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('notification routes cover dashboard rail channels', function () {",
        "  pm.response.to.have.status(200);",
        "  const channels = pm.response.json().items.map((item) => item.channel);",
        "  pm.expect(channels).to.include('email');",
        "  pm.expect(channels).to.include('push');",
        "  pm.expect(channels).to.include('dashboard');",
        "});"
      ] } }]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:18080" }
  ]
}
