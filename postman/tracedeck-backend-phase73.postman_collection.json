{
  "info": {
    "name": "TraceDeck Backend Phase 73",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('health is ok', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Dashboard Provenance UI",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('dashboard exposes provenance controls', function () {",
              "  pm.response.to.have.status(200);",
              "  const html = pm.response.text();",
              "  pm.expect(html).to.include('sourceBadge');",
              "  pm.expect(html).to.include('theme-toggle-button');",
              "  pm.expect(html).to.include('server-status-light');",
              "  pm.expect(html).to.include('browser-activity-button');",
              "  pm.expect(html).to.include('dashboard-page-nav');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Browser Activity Provenance UI",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/browser-activity"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('browser activity page exposes source column', function () {",
              "  pm.response.to.have.status(200);",
              "  const html = pm.response.text();",
              "  pm.expect(html).to.include('TraceDeck Browser Activity');",
              "  pm.expect(html).to.include('<th>Source</th>');",
              "  pm.expect(html).to.include('sourceBadge');",
              "  pm.expect(html).to.include('metadata-only guard');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Browser Activity API Provenance",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/tenants/family-varadha/browser-activity?limit=25"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('browser activity rows include typed provenance', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.summary.total).to.be.at.least(3);",
              "  pm.expect(body.items.length).to.be.at.least(3);",
              "  body.items.forEach(function (item) {",
              "    pm.expect(item.source_kind).to.be.a('string').and.not.empty;",
              "    pm.expect(item.evidence_scope).to.be.a('string').and.not.empty;",
              "    pm.expect(item.evidence_detail).to.be.a('string').and.not.empty;",
              "  });",
              "  const sourceKinds = body.items.map(function (item) { return item.source_kind; });",
              "  pm.expect(sourceKinds).to.include('demo_seed');",
              "  pm.expect(body.privacy_boundary).to.include('metadata-only');",
              "  const serialized = JSON.stringify(body).toLowerCase();",
              "  ['smtp_password', 'provider_secret', 'push_endpoint', 'screenshot_bytes', 'raw_url', 'page_title', 'cookie_value', 'token_value', 'password_value', 'keylogger'].forEach(function (marker) {",
              "    pm.expect(serialized).to.not.include(marker);",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Device Alert Delivery Provenance",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/devices/demo-study-laptop/alert-deliveries"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('delivery rows identify demo proof', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.count).to.be.at.least(1);",
              "  body.items.forEach(function (item) {",
              "    pm.expect(item.source_kind).to.eql('demo_seed');",
              "    pm.expect(item.evidence_scope).to.eql('delivery_proof');",
              "    pm.expect(item.evidence_detail).to.include('Seeded');",
              "  });",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
