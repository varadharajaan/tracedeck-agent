{
  "info": {
    "name": "TraceDeck Backend Phase 69",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('health is ok', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Dashboard Multipage Theme Status",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('dashboard contains Phase 69 UI controls', function () {",
              "  pm.response.to.have.status(200);",
              "  const html = pm.response.text();",
              "  pm.expect(html).to.include('theme-toggle-button');",
              "  pm.expect(html).to.include('server-status-light');",
              "  pm.expect(html).to.include('dashboard-page-nav');",
              "  pm.expect(html).to.include('sourceBadge');",
              "  pm.expect(html).to.include('data-page-target=\"notifications\"');",
              "  pm.expect(html).to.include('data-page-target=\"hosts\"');",
              "  pm.expect(html).to.include('browser-activity-button');",
              "  pm.expect(html).to.include('/browser-activity');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Browser Activity Page Theme Status",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/browser-activity"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('browser page contains Phase 69 UI controls', function () {",
              "  pm.response.to.have.status(200);",
              "  const html = pm.response.text();",
              "  pm.expect(html).to.include('TraceDeck Browser Activity');",
              "  pm.expect(html).to.include('theme-toggle-button');",
              "  pm.expect(html).to.include('server-status-light');",
              "  pm.expect(html).to.include('Browser Domain Activity');",
              "  pm.expect(html).to.include('<th>Source</th>');",
              "  pm.expect(html).to.include('metadata-only guard');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Tenant Browser Activity API",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/tenants/family-varadha/browser-activity?limit=25"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('browser activity remains typed and metadata-only', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.summary.total).to.be.at.least(3);",
              "  pm.expect(body.summary.chrome).to.be.at.least(1);",
              "  pm.expect(body.summary.edge).to.be.at.least(1);",
              "  pm.expect(body.summary.brave).to.be.at.least(1);",
              "  pm.expect(body.summary.study_safe).to.be.at.least(1);",
              "  pm.expect(body.summary.non_study_youtube).to.be.at.least(1);",
              "  pm.expect(body.summary.notification_proof).to.be.at.least(1);",
              "  pm.expect(body.hosts.length).to.be.at.least(1);",
              "  pm.expect(body.browsers.length).to.be.at.least(3);",
              "  pm.expect(body.items.length).to.be.at.least(3);",
              "  pm.expect(body.items[0].source_kind).to.be.a('string').and.not.empty;",
              "  pm.expect(body.items[0].evidence_scope).to.be.a('string').and.not.empty;",
              "  pm.expect(body.items[0].evidence_detail).to.be.a('string').and.not.empty;",
              "  pm.expect(body.privacy_boundary).to.include('metadata-only');",
              "  const serialized = JSON.stringify(body).toLowerCase();",
              "  ['smtp_password', 'provider_secret', 'push_endpoint', 'screenshot_bytes', 'raw_url', 'page_title', 'cookie_value', 'token_value', 'password_value', 'keylogger'].forEach(function (marker) {",
              "    pm.expect(serialized).to.not.include(marker);",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Tenant Browser Activity Filter",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/tenants/family-varadha/browser-activity?browser=edge&study_safe=false&limit=10"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('browser activity filter returns Edge review rows', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.filters.browser).to.eql('edge');",
              "  pm.expect(body.filters.study_safe).to.eql(false);",
              "  pm.expect(body.items.length).to.be.at.least(1);",
              "  body.items.forEach(function (item) {",
              "    pm.expect(item.browser).to.eql('edge');",
              "    pm.expect(item.study_safe).to.eql(false);",
              "  });",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
